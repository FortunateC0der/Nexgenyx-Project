<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Validate_PAN_Number_Format</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT(ISBLANK(PAN_Number__c)),
  NOT(REGEX(PAN_Number__c, &quot;[0-9]{10}&quot;))
)</errorConditionFormula>
    <errorDisplayField>PAN_Number__c</errorDisplayField>
    <errorMessage>PAN Number must be exactly 10 digits (numeric only). Example: 1234567890</errorMessage>
</ValidationRule>
