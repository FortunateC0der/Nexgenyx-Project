        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_if_income_proof_uploaded</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>ParentRecordId</field>
